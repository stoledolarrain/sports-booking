<%- include('../components/header.ejs') %>

<div class="container my-5">
  <div class="text-center mb-5">
    <h1 class="fw-bold text-dark">Reserva tu Cancha</h1>
    <p class="text-muted text-center">Elige tu cancha favorita y selecciona un horario disponible.</p>
  </div>

  <div class="row g-4">
    <% if (canchas && canchas.length > 0) { %>
      <% canchas.forEach(cancha => { %>
        
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 rounded-4">
            <div class="card-header bg-dark text-white text-center py-3 rounded-top-4">
              <h5 class="mb-0 fw-bold"><%= cancha.nombre %></h5>
              <small class="badge bg-success mt-2"><%= cancha.TipoCancha ? cancha.TipoCancha.nombre : 'General' %></small>
            </div>
            
            <div class="card-body bg-light">
              <h6 class="text-center text-success fw-bold mb-4">Precio: <%= cancha.precio_por_hora %> Bs/Hr</h6>
              
              <p class="fw-semibold text-secondary mb-2">Horarios Disponibles:</p>
              
              <% if (cancha.Horarios && cancha.Horarios.length > 0) { %>
                <div class="d-grid gap-2">
                  <% cancha.Horarios.forEach(horario => { %>
                    <form action="/reservar/<%= horario.id %>" method="post">
                      <button type="submit" class="btn btn-outline-primary w-100 text-start d-flex justify-content-between align-items-center" onclick="return confirm('¿Confirmas tu reserva para el <%= horario.fecha %> a las <%= horario.hora_inicio %>?');">
                        <span><%= horario.fecha %></span>
                        <span class="badge bg-primary rounded-pill"><%= horario.hora_inicio %> - <%= horario.hora_fin %></span>
                      </button>
                    </form>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="alert alert-secondary text-center small mb-0" role="alert">
                  No hay horarios libres por ahora.
                </div>
              <% } %>

            </div>
          </div>
        </div>

      <% }) %>
    <% } else { %>
      <div class="col-12 text-center">
        <h4 class="text-muted">En este momento no hay canchas activas. Vuelve más tarde.</h4>
      </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>