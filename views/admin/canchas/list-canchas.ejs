<%- include('../../components/header.ejs') %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Gestión de Canchas</h2>
    <a href="/admin/canchas/crear" class="btn btn-success fw-bold">+ Nueva Cancha</a>
  </div>

  <%- include('../../components/error-panel.ejs') %>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Nombre</th>
            <th>Tipo</th>
            <th>Precio/Hr</th>
            <th>Estado</th>
            <th class="text-end pe-4">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (canchas && canchas.length > 0) { %>
            <% canchas.forEach(cancha => { %>
              <tr>
                <td class="ps-4 fw-bold"><%= cancha.nombre %></td>
                <td><%= cancha.TipoCancha ? cancha.TipoCancha.nombre : 'Sin tipo' %></td>
                <td>$<%= cancha.precio_por_hora %></td>
                <td>
                  <% if(cancha.estado === 'activa') { %>
                    <span class="badge bg-success">Activa</span>
                  <% } else { %>
                    <span class="badge bg-danger">Inactiva</span>
                  <% } %>
                </td>
                <td class="text-end pe-4">
                  <a href="/admin/canchas/editar/<%= cancha.id %>" class="btn btn-sm btn-primary">Editar</a>
                  <a href="/admin/canchas/eliminar/<%= cancha.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar cancha?')">Eliminar</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center py-4 text-muted">No hay canchas registradas.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="text-secondary text-decoration-none">← Volver al Panel</a>
  </div>
</div>

<%- include('../../components/footer.ejs') %>