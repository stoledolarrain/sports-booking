<%- include('../components/header.ejs') %>

<div class="container py-5">
  <div class="row mb-4">
    <div class="col">
      <h2 class="fw-bold text-dark">Panel de Administrador</h2>
      <p class="text-muted">Gestiona las canchas, horarios, reservas y reseñas del sistema.</p>
    </div>
  </div>

  <%- include('../components/error-panel.ejs') %>

  <div class="row g-4 text-center">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
        <div class="card-body">
          <h4 class="fw-bold text-success">Canchas</h4>
          <p class="text-muted">Crea, edita y elimina las canchas del complejo.</p>
          <a href="/admin/canchas" class="btn btn-outline-success w-100">Gestionar Canchas</a>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
        <div class="card-body">
          <h4 class="fw-bold text-success">Tipos de Cancha</h4>
          <p class="text-muted">Administra las categorías (Fútbol, Pádel, etc.).</p>
          <a href="/admin/tipos-cancha" class="btn btn-outline-success w-100">Gestionar Tipos</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
        <div class="card-body">
          <h4 class="fw-bold text-success">Horarios</h4>
          <p class="text-muted">Abre o cierra horarios disponibles para reservas.</p>
          <a href="/admin/horarios" class="btn btn-outline-success w-100">Gestionar Horarios</a>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
        <div class="card-body">
          <h4 class="fw-bold text-primary">Reservas</h4>
          <p class="text-muted">Mira todas las reservas y cambia sus estados.</p>
          <a href="/admin/reservas" class="btn btn-outline-primary w-100">Ver Reservas</a>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
        <div class="card-body">
          <h4 class="fw-bold text-warning">Reseñas</h4>
          <p class="text-muted">Lee lo que los usuarios opinan de las canchas.</p>
          <a href="/admin/resenas" class="btn btn-outline-warning w-100 text-dark">Ver Reseñas</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../components/footer.ejs') %>