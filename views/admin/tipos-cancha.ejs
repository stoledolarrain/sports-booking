<%- include('../components/header.ejs') %>

<div class="container my-5">
  <div class="row mb-4">
    <div class="col-12">
      <h2 class="fw-bold">Administración de Tipos de Cancha</h2>
      <p class="text-muted">Agrega o elimina las categorías (Ej. Fútbol 5, Tenis, etc.)</p>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-4">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold">
          Nuevo Tipo
        </div>
        <div class="card-body">
          <form action="/admin/tipos-cancha" method="post">
            <div class="mb-3">
              <label for="nombre" class="form-label text-secondary fw-semibold">Nombre de la Categoría</label>
              <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Ej. Fútbol 7" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Guardar Tipo</button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">ID</th>
                <th>Nombre</th>
                <th class="text-end pe-4">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% if (tipos.length > 0) { %>
                <% tipos.forEach(tipo => { %>
                  <tr>
                    <td class="ps-4 fw-bold text-secondary"><%= tipo.id %></td>
                    <td><%= tipo.nombre %></td>
                    <td class="text-end pe-4">
                      <form action="/admin/tipos-cancha/delete/<%= tipo.id %>" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Estás seguro de que deseas eliminar este tipo de cancha?');">
                          Eliminar
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="3" class="text-center text-muted py-4">No hay tipos de cancha registrados aún. ¡Agrega el primero!</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>