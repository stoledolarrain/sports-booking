<%- include('../../components/header.ejs') %>

<div class="container py-5">
  <h2 class="fw-bold text-dark mb-4">Reseñas de Clientes</h2>

  <%- include('../../components/error-panel.ejs') %>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Cancha</th>
            <th>Cliente</th>
            <th>Calificación</th>
            <th>Comentario</th>
          </tr>
        </thead>
        <tbody>
          <% if (resenas && resenas.length > 0) { %>
            <% resenas.forEach(resena => { %>
              <tr>
                <td class="ps-4 fw-bold"><%= resena.Cancha ? resena.Cancha.nombre : 'N/A' %></td>
                <td><%= resena.Usuario ? resena.Usuario.nombre : 'N/A' %></td>
                <td>
                  <span class="text-warning fw-bold"><%= resena.calificacion %> / 5</span>
                  ⭐
                </td>
                <td class="text-muted fst-italic">
                  "<%= resena.comentario ? resena.comentario : 'Sin comentario' %>"
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="text-center py-4 text-muted">Aún no hay reseñas registradas.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="text-secondary text-decoration-none">← Volver al Panel</a>
  </div>
</div>

<%- include('../../components/footer.ejs') %>