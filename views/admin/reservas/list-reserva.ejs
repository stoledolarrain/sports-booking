<%- include('../../components/header.ejs') %>

<div class="container py-5">
  <h2 class="fw-bold text-dark mb-4">Gestión de Reservas</h2>

  <%- include('../../components/error-panel.ejs') %>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th class="ps-4">ID</th>
            <th>Cliente</th>
            <th>Cancha</th>
            <th>Fecha y Hora</th>
            <th>Estado</th>
            <th class="text-end pe-4">Acción</th>
          </tr>
        </thead>
        <tbody>
          <% if (reservas && reservas.length > 0) { %>
            <% reservas.forEach(reserva => { %>
              <tr>
                <td class="ps-4 fw-bold text-secondary">#<%= reserva.id %></td>
                <td>
                  <%= reserva.Usuario ? reserva.Usuario.nombre : 'N/A' %><br>
                  <small class="text-muted"><%= reserva.Usuario ? reserva.Usuario.email : '' %></small>
                </td>
                <td>
                  <%= reserva.Horario && reserva.Horario.Cancha ? reserva.Horario.Cancha.nombre : 'N/A' %>
                </td>
                <td>
                  <%= reserva.Horario ? reserva.Horario.fecha : '' %> <br>
                  <small class="text-muted">
                    <%= reserva.Horario ? reserva.Horario.hora_inicio + ' - ' + reserva.Horario.hora_fin : '' %>
                  </small>
                </td>
                <td>
                  <% if(reserva.estado === 'confirmada') { %>
                    <span class="badge bg-success">Confirmada</span>
                  <% } else { %>
                    <span class="badge bg-danger">Cancelada</span>
                  <% } %>
                </td>
                <td class="text-end pe-4">
                  <form action="/admin/reservas/cambiar-estado/<%= reserva.id %>" method="POST" class="d-inline">
                    <% if(reserva.estado === 'confirmada') { %>
                      <input type="hidden" name="nuevo_estado" value="cancelada">
                      <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Cancelar esta reserva?')">Cancelar Reserva</button>
                    <% } else { %>
                      <input type="hidden" name="nuevo_estado" value="confirmada">
                      <button type="submit" class="btn btn-sm btn-outline-success">Confirmar Reserva</button>
                    <% } %>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-4 text-muted">No hay reservas registradas.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="text-secondary text-decoration-none">← Volver al Panel</a>
  </div>
</div>

<%- include('../../components/footer.ejs') %>