<%- include('../../components/header.ejs') %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Horarios Disponibles</h2>
    <a href="/admin/horarios/crear" class="btn btn-success fw-bold">+ Agregar Horario</a>
  </div>

  <%- include('../../components/error-panel.ejs') %>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Cancha</th>
            <th>Fecha</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Estado</th>
            <th class="text-end pe-4">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (horarios && horarios.length > 0) { %>
            <% horarios.forEach(horario => { %>
              <tr>
                <td class="ps-4 fw-bold"><%= horario.Cancha ? horario.Cancha.nombre : 'N/A' %></td>
                <td><%= horario.fecha %></td>
                <td><%= horario.hora_inicio %></td>
                <td><%= horario.hora_fin %></td>
                <td>
                  <% if(horario.disponible) { %>
                    <span class="badge bg-success">Libre</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Ocupado</span>
                  <% } %>
                </td>
                <td class="text-end pe-4">
                  <a href="/admin/horarios/eliminar/<%= horario.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar horario?')">Eliminar</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-4 text-muted">No hay horarios cargados.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="text-secondary text-decoration-none">← Volver al Panel</a>
  </div>
</div>

<%- include('../../components/footer.ejs') %>