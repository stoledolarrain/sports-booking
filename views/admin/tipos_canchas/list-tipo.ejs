<%- include('../../components/header.ejs') %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Tipos de Cancha</h2>
    <a href="/admin/tipos-cancha/crear" class="btn btn-success fw-bold">+ Nuevo Tipo</a>
  </div>

  <%- include('../../components/error-panel.ejs') %>

  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">ID</th>
            <th>Nombre</th>
            <th class="text-end pe-4">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (tipos && tipos.length > 0) { %>
            <% tipos.forEach(tipo => { %>
              <tr>
                <td class="ps-4 fw-bold text-secondary"><%= tipo.id %></td>
                <td><%= tipo.nombre %></td>
                <td class="text-end pe-4">
                  <a href="/admin/tipos-cancha/editar/<%= tipo.id %>" class="btn btn-sm btn-primary">Editar</a>
                  <a href="/admin/tipos-cancha/eliminar/<%= tipo.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Seguro que deseas eliminar esto?')">Eliminar</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="3" class="text-center py-4 text-muted">No hay tipos de cancha registrados.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    <a href="/admin" class="text-secondary text-decoration-none">← Volver al Panel</a>
  </div>
</div>

<%- include('../../components/footer.ejs') %>