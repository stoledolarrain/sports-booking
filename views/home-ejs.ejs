<%- include('components/header.ejs') %>
<div class="container">
  <section class="container py-5">
    <div class="row align-items-center">
      <div class="col-md-6">
        <h1 class="display-4 fw-bold text-dark mb-3">
          Tu cancha favorita, a un solo clic de distancia.
        </h1>
        <p class="lead text-muted mb-4">
          Bienvenido a ACE, el sistema definitivo para encontrar y reservar
          canchas de fútbol, tenis, pádel y más. Gestiona tus horarios y asegura
          tu partido sin complicaciones.
        </p>
      </div>
      <div class="col-md-6 mt-4 mt-md-0">
        <img
          src="/images/cancha-de-tennis.png"
          alt="Personas jugando deporte"
          class="img-fluid rounded shadow"
        />
      </div>
    </div>
  </section>

  <section class="container py-5">
    <div class="container">
      <div class="row text-center">
        <div class="col-md-4 mb-4">
          <div class="card h-100 border-0 shadow-sm p-3">
            <div class="card-body">
              <h3 class="h5 fw-bold">Variedad de Deportes</h3>
              <p class="text-muted">
                Encuentra canchas para fútbol, tenis, pádel y mucho más en un
                solo lugar.
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card h-100 border-0 shadow-sm p-3">
            <div class="card-body">
              <h3 class="h5 fw-bold">Disponibilidad en Tiempo Real</h3>
              <p class="text-muted">
                Revisa los horarios libres y reserva instantáneamente sin tener
                que llamar.
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card h-100 border-0 shadow-sm p-3">
            <div class="card-body">
              <h3 class="h5 fw-bold">Sistema de Reseñas</h3>
              <p class="text-muted">
                Lee las opiniones de otros jugadores y deja tu calificación
                después de jugar.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="canchas" class="container py-5">
    <h2 class="text-center fw-bold mb-5">Nuestras Canchas</h2>
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-futbol.jpg"
            class="card-img-top"
            alt="Cancha de Fútbol"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Fútbol</h5>
            <p class="card-text text-muted">
              Césped sintético de alta calidad para partidos de 5, 7 y 11
              jugadores.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-tennis2.jpg"
            class="card-img-top"
            alt="Cancha de Tenis"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Tenis</h5>
            <p class="card-text text-muted">
              Superficies de polvo de ladrillo y cemento en perfectas
              condiciones.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-padel.jpg"
            class="card-img-top"
            alt="Cancha de Pádel"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Pádel</h5>
            <p class="card-text text-muted">
              Canchas de cristal con iluminación LED profesional.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-basquet.jpg"
            class="card-img-top"
            alt="Cancha de Basquetball"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Basquetball</h5>
            <p class="card-text text-muted">
              Canchas de madera con tableros profesionales y aros regulables.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-voley.jpg"
            class="card-img-top"
            alt="Cancha de Voley"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Voley</h5>
            <p class="card-text text-muted">
              Canchas de superficie dura para partidos recreativos y
              competitivos.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
          <img
            src="/images/cancha-de-fronton.jpg"
            class="card-img-top"
            alt="Cancha de Fronton"
            style="height: 250px; object-fit: cover"
          />
          <div class="card-body">
            <h5 class="card-title fw-bold">Canchas de Fronton</h5>
            <p class="card-text text-muted">
              Canchas de pared para jugar frontón con pelota de goma.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<%- include('components/footer.ejs') %>
