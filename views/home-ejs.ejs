<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <title>ACE - Reservas Deportivas</title>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary shadow-sm">
      <div class="container">
        <a class="navbar-brand" href="/">
          <img src="/images/logo-ace.png" alt="Logo ACE" height="60" />
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link active" href="/">Inicio</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#canchas">Canchas</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">Iniciar Sesión</a>
            </li>
            <li class="nav-item">
              <a class="btn btn-success ms-2" href="#">Regístrate</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <header class="container py-5 mt-4">
      <div class="row align-items-center">
        <div class="col-md-6">
          <h1 class="display-4 fw-bold text-dark mb-3">
            Tu cancha favorita, a un solo clic de distancia.
          </h1>
          <p class="lead text-muted mb-4">
            Bienvenido a ACE, el sistema definitivo para encontrar y reservar
            canchas de fútbol, tenis, pádel y más. Gestiona tus horarios y
            asegura tu partido sin complicaciones.
          </p>
        </div>
        <div class="col-md-6 mt-4 mt-md-0">
          <img
            src="/images/cancha-de-tennis.png"
            alt="Personas jugando deporte"
            class="img-fluid rounded shadow"
          />
        </div>
      </div>
    </header>

    <section class="bg-light py-5">
      <div class="container">
        <div class="row text-center">
          <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-3">
              <div class="card-body">
                <h3 class="h5 fw-bold">Variedad de Deportes</h3>
                <p class="text-muted">
                  Encuentra canchas para fútbol, tenis, pádel y mucho más en un
                  solo lugar.
                </p>
              </div>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-3">
              <div class="card-body">
                <h3 class="h5 fw-bold">Disponibilidad en Tiempo Real</h3>
                <p class="text-muted">
                  Revisa los horarios libres y reserva instantáneamente sin
                  tener que llamar.
                </p>
              </div>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm p-3">
              <div class="card-body">
                <h3 class="h5 fw-bold">Sistema de Reseñas</h3>
                <p class="text-muted">
                  Lee las opiniones de otros jugadores y deja tu calificación
                  después de jugar.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="canchas" class="container py-5">
      <h2 class="text-center fw-bold mb-5">Nuestras Canchas</h2>
      <div class="row">
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100">
            <img
              src="/images/cancha-de-futbol.jpg"
              class="card-img-top"
              alt="Cancha de Fútbol"
            />
            <div class="card-body">
              <h5 class="card-title fw-bold">Canchas de Fútbol</h5>
              <p class="card-text text-muted">
                Césped sintético de alta calidad para partidos de 5, 7 y 11
                jugadores.
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100">
            <img
              src="/images/cancha-de-tennis2.jpg"
              class="card-img-top"
              alt="Cancha de Tenis"
            />
            <div class="card-body">
              <h5 class="card-title fw-bold">Canchas de Tenis</h5>
              <p class="card-text text-muted">
                Superficies de polvo de ladrillo y cemento en perfectas
                condiciones.
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100">
            <img
              src="/images/cancha-de-padel.jpg"
              class="card-img-top"
              alt="Cancha de Pádel"
            />
            <div class="card-body">
              <h5 class="card-title fw-bold">Canchas de Pádel</h5>
              <p class="card-text text-muted">
                Canchas de cristal con iluminación LED profesional.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer class="bg-dark text-white py-4 mt-5">
      <div class="container text-center">
        <p class="mb-0">
          &copy; 2025 ACE - Sistema de Gestión de Reservas. Todos los derechos
          reservados.
        </p>
      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
